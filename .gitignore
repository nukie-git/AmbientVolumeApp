# --- CURRENT SETTINGS ---
*.hprof
*.iml
*.iml
.DS_Store
.cxx
.externalNativeBuild
.gradle/
.idea/
.kotlin/
.kotlin/errors
.vscode
/Ambient_Volume_prompt.md
/build
/captures
/docs/conversations
local.properties

# --- PROFESSIONAL IDE & TOOLING ---
# We ignore the entire .idea folder to prevent deployment targets,
# device caches, and AI (Studio Bot) history from being committed.
.idea/
# EXCEPTION: We allow the VCS file so contributors know it's a Git repo
!.idea/vcs.xml
# EXCEPTION: We allow the code styles if you have specific formatting
!.idea/codeStyles/

# --- ANDROID SPECIFIC ---
# Ignore built APKs and AABs (they should be in Releases, not the repo)
*.apk
*.ap_
*.aab
*.dex

# Ignore generated Google Services (if used in future)
google-services.json

# --- SECURITY & PRIVACY (CRITICAL for FOSS) ---
# Never commit your signing keys or passwords
*.jks
*.keystore
*.p12
*.pfx
*.key
signing.properties
secrets.properties
keystore.properties
debug.keystore
release.keystore

# Environment variable files (API keys, secrets)
.env
.env.*
*.env
!.env.example

# --- SYSTEM & TEMP FILES ---
# Ignore OS-generated files that clutter the repo
Thumbs.db
*.swp
*~
.stackdump
*.log
lint-results*

# --- PERSONAL WORKFLOW ---
# AI agent config and skills (machine-specific)
.agents/

# --- GRADLE WRAPPER ---
# We explicitly DO NOT ignore these. FOSS projects need the wrapper
# to ensure anyone can build your app without installing Gradle.
# !gradle/wrapper/gradle-wrapper.jar
# !gradle/wrapper/gradle-wrapper.properties

# --- BUILD OUTPUT ---
# Ignore release-specific build output directory
/app/release/

# --- EDITOR & TOOLING OVERRIDES ---
# VS Code workspace settings (for contributors using VS Code)
.vscode/
# Backup and temporary files created by editors
*.bak
*.tmp
